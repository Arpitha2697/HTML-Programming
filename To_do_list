#include <stdio.h>
#include <string.h>

#define MAX_TASKS 10
#define TASK_LENGTH 100

// Structure to represent a task
typedef struct {
    char description[TASK_LENGTH];
    int isCompleted;
} Task;

int main() {
    Task todoList[MAX_TASKS];
    int taskCount = 0;
    int choice;

    while (1) {
        printf("\n--- TO-DO LIST ---\n");
        printf("1. Add Task\n");
        printf("2. View Tasks\n");
        printf("3. Mark Task as Completed\n");
        printf("4. Exit\n");
        printf("Enter your choice (1-4): ");
        scanf("%d", &choice);
        getchar(); // Clear the newline character from the buffer

        switch (choice) {
            case 1:
                if (taskCount < MAX_TASKS) {
                    printf("Enter the task: ");
                    fgets(todoList[taskCount].description, TASK_LENGTH, stdin);
                    
                    // Remove trailing newline from fgets
                    todoList[taskCount].description[strcspn(todoList[taskCount].description, "\n")] = 0;
                    
                    todoList[taskCount].isCompleted = 0; // 0 means not completed
                    taskCount++;
                    printf("Task added successfully!\n");
                } else {
                    printf("Your to-do list is full!\n");
                }
                break;

            case 2:
                if (taskCount == 0) {
                    printf("No tasks in your list yet.\n");
                } else {
                    printf("\nYour Tasks:\n");
                    for (int i = 0; i < taskCount; i++) {
                        printf("%d. [%s] %s\n", 
                               i + 1, 
                               todoList[i].isCompleted ? "X" : " ", 
                               todoList[i].description);
                    }
                }
                break;

            case 3:
                if (taskCount == 0) {
                    printf("No tasks to complete.\n");
                } else {
                    int taskNumber;
                    printf("Enter task number to mark as completed: ");
                    scanf("%d", &taskNumber);
                    
                    if (taskNumber > 0 && taskNumber <= taskCount) {
                        todoList[taskNumber - 1].isCompleted = 1;
                        printf("Task marked as completed!\n");
                    } else {
                        printf("Invalid task number.\n");
                    }
                }
                break;

            case 4:
                printf("Exiting... Have a productive day!\n");
                return 0;

            default:
                printf("Invalid choice! Please enter a number between 1 and 4.\n");
        }
    }
    return 0;
}
